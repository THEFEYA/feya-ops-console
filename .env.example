# Supabase — публичные (безопасны для клиента)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — ТОЛЬКО серверная сторона, НИКОГДА не в браузере
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Токен доступа к дашборду (обязательно поменяйте на длинную случайную строку)
FEYA_DASH_TOKEN=your-secret-token-here

# Включить проверку токена (true/false)
FEYA_DASH_TOKEN_REQUIRED=true

# Опционально: NODE_ENV=development включает /debug/schema
# NODE_ENV=development
